{
  "name": "wingman",
  "version": "2.0.0",
  "build": 20,
  "description": "Browser-based mission control for Claude Code sessions",
  "keywords": ["claude", "claude-code", "terminal", "prompt", "ai", "anthropic"],
  "main": "server.js",
  "bin": {
    "wingman": "./bin/wingman.js"
  },
  "files": [
    "bin/",
    "lib/*.js",
    "public/*.html",
    "public/*.css",
    "public/*.js",
    "server.js"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "node-pty": "^1.1.0",
    "open": "^10.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
